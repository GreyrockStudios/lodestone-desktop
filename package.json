{
  "name": "lodestone",
  "version": "0.5.46",
  "description": "Lodestone — Your AI brain, always learning",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:data-layer": "bash build-data-layer.sh",
    "build:mac": "npm run build:data-layer && electron-builder --mac",
    "build:mac-universal": "npm run build:data-layer && electron-builder --mac --universal",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build": "npm run build:data-layer && electron-builder",
    "pull-ui": "rsync -avz --delete root@159.89.239.126:/var/www/lodestone/ ui/ --exclude updates --exclude lodestone --exclude downloads --exclude '*.dmg' --exclude '*.exe' --exclude '*.blockmap' --exclude dist.bak --exclude 'assets.bak.*' --exclude .DS_Store --exclude '*.pkg' --exclude '*.zip'",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Greyrock Studio",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/GreyrockStudios/lodestone-desktop.git"
  },
  "dependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "socket.io-client": "^4.8.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.heylodestone.app",
    "productName": "Lodestone",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "db.js",
      "desktop-tools.js",
      "scheduler.js",
      "community-data-layer.js",
      "build-data-layer.sh",
      {
        "from": "lib",
        "to": "lib",
        "filter": [
          "**/*.js"
        ]
      },
      {
        "from": "brain",
        "to": "brain",
        "filter": [
          "**/*.js"
        ]
      },
      "mcp-bridge.js",
      "mcp-servers.json",
      "protocol-handler.js",
      {
        "from": "ui",
        "to": "ui",
        "filter": [
          "**/*",
          "!**/*.dmg",
          "!**/*.zip",
          "!**/*.blockmap",
          "!**/*.exe",
          "!**/dist.bak"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "ui",
        "to": "ui"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "minimumSystemVersion": "10.15",
      "identity": "8A2CCFFDC7574EBDA389C957A1E4D90BF336915F",
      "notarize": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Productivity",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "generic",
      "url": "https://api.heylodestone.com/api/updates"
    }
  }
}
